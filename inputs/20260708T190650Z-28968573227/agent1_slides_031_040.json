      "slide_or_page": 35,
      "element_type": "text_box",
      "element_id": "slide_35_TextBox_6",
      "source_text": "A cross-functional task force may be used to consider:\nWhat to outsource (or whether the proposed activity is  suitable for outsourcing)\nThe business case for outsourcing (strategic reasons; cost comparisons of internal and external provision; anticipated benefits and risks/problems; and possible impacts on staff, capital, finance and competitive advantage)",
      "character_count": 359,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: TextBox 6",
      "translation_status": "PENDING",
