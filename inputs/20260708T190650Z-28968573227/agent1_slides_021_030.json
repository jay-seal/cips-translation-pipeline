      "element_id": "slide_29_Content_Placeholder_8_row0_col0",
      "source_text": "DEFINITION",
      "character_count": 10,
      "is_in_text_box": true,
      "is_in_table": true,
      "layout_context": "Table row 1, column 1",
      "translation_status": "PENDING",
      "translated_text": null,
