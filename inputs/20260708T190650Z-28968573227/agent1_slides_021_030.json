      "element_type": "text_box",
      "element_id": "slide_27_Content_Placeholder_2",
      "source_text": "Using your organisation, itemise the costs that are not related to procurement and so will be internal to the business.",
      "character_count": 119,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Content Placeholder 2",
