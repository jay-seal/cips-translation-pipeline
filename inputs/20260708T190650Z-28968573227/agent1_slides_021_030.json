    {
      "segment_id": "SEG-050",
      "slide_or_page": 25,
      "element_type": "text_box",
      "element_id": "slide_25_Rectangle_2",
      "source_text": "An example of the importance of procurement is provided by McKinsey when they commented that:",
      "character_count": 93,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Rectangle 2",
      "translation_status": "PENDING",
      "translated_text": null,
      "flag_status": null,
      "flag_options": null,
      "expansion_risk": null
    },
    {
      "segment_id": "SEG-051",
      "slide_or_page": 25,
      "element_type": "text_box",
      "element_id": "slide_25_Rectangle_4",
      "source_text": "“Procurement is another financial management process that can be optimised to produce rapid savings without diminishing levels of service. Purchased goods and services account for 1/3 of total public spending in OECD countries....Different agencies in the same government often pay vastly different prices for the same things. Fortunately savings can often be realised quickly by introducing better procurement practices”",
      "character_count": 421,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Rectangle 4",
      "translation_status": "PENDING",
      "translated_text": null,
      "flag_status": null,
      "flag_options": null,
      "expansion_risk": null
    },
    {
      "segment_id": "SEG-052",
      "slide_or_page": 25,
      "element_type": "text_box",
      "element_id": "slide_25_Rectangle_7",
      "source_text": "Source: McKinsey, Better for Less Improving Public Sector Performance on a Tight Budget (2011)",
      "character_count": 94,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Rectangle 7",
      "translation_status": "PENDING",
      "translated_text": null,
      "flag_status": null,
      "flag_options": null,
      "expansion_risk": null
    },
    {
      "segment_id": "SEG-053",
      "slide_or_page": 26,
      "element_type": "slide_title",
      "element_id": "slide_26_Title_3",
      "source_text": "The Proportion of Costs Accounted for by Procurement",
      "character_count": 52,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Title 3",
      "translation_status": "PENDING",
      "translated_text": null,
