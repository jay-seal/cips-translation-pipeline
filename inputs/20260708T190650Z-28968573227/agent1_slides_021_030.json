      "segment_id": "SEG-054",
      "slide_or_page": 26,
      "element_type": "text_box",
      "element_id": "slide_26_Rectangle_2",
      "source_text": "It is possible through open book accounting to evaluate the costs of purchases and  to produce a cost model.\nThis will also help distinguish the proportions of suppliers costs that are accounted for by their purchases",
      "character_count": 217,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Rectangle 2",
      "translation_status": "PENDING",
