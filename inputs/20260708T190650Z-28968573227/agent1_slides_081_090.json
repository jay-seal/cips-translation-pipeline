    {
      "segment_id": "SEG-013",
      "slide_or_page": 82,
      "element_type": "text_box",
      "element_id": "slide_82_Text_Placeholder_3",
      "source_text": "Ensure that bought-in materials, goods & services comply with defined public standards and specifications\nSourcing exercises are compliant with any stated policies that apply to a particular sector and all resulting supply chain operations are compliant with law, regulation & standards that apply such as:\nHealth and safety\nEnvironmental sustainability\nEmployment rights\nData protection\nModern Slavery",
      "character_count": 402,
      "is_in_text_box": true,
