      "expansion_risk": null
    },
    {
      "segment_id": "SEG-015",
      "slide_or_page": 83,
      "element_type": "text_box",
      "element_id": "slide_83_Text_Placeholder_3",
      "source_text": "Health & Safety at Work etc. Act 1974\nThe Corporate Manslaughter & Homicide Act 2007\nThe health and safety of employees is part of an employers duty of care and one that is defined and enforced through legal obligations.\nThe first aim is to promote the well-being of workers in occupations and to prevent accidents that cause injury as a result of their working conditions\nIt also includes the placing and maintenance of the worker in an occupational environment adapted to their physiological and psychological capabilities\nHealth and safety in the workplace aims to improve the working environment promoting a positive social climate and smooth operation that enhances productivity of workers.",
      "character_count": 695,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Text Placeholder 3",
