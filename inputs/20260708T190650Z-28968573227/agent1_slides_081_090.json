      "slide_or_page": 83,
      "element_type": "slide_title",
      "element_id": "slide_83_Title_3",
      "source_text": "Health and Safety",
      "character_count": 17,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Title 3",
      "translation_status": "PENDING",
      "translated_text": null,
