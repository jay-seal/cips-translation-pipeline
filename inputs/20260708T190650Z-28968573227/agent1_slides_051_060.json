      "slide_or_page": 58,
      "element_type": "text_box",
      "element_id": "slide_58_Rectangle_2",
      "source_text": "A key role of procurement can be to influence the organisation’s Triple Bottom Line:",
      "character_count": 84,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Rectangle 2",
      "translation_status": "PENDING",
      "translated_text": null,
      "flag_status": null,
      "flag_options": null,
      "expansion_risk": null
    },
    {
      "segment_id": "SEG-040",
      "slide_or_page": 58,
      "element_type": "text_box",
      "element_id": "slide_58_Rectangle_5",
      "source_text": "The challenge was that companies should be responsible for three separate bottom lines:\nThe bottom line measure of corporate profit - “profit account”\nThe bottom line of a company's “people account”— a measure in some shape or form of how an organisation is socially responsible.\nThe bottom line of the company's “planet” account” — a measure of how environmentally responsible it has been in its activities.",
      "character_count": 408,
      "is_in_text_box": true,
      "is_in_table": false,
      "layout_context": "Shape: Rectangle 5",
      "translation_status": "PENDING",
      "translated_text": null,
      "flag_status": null,
      "flag_options": null,
      "expansion_risk": null
    },
